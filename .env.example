NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버에서 관리자 기능으로 Supabase를 수정할 때 사용하는 비공개 키
SUPABASE_SERVICE_ROLE_KEY=

# 실제 배포 주소 (예: https://www.example.com)
NEXT_PUBLIC_SITE_URL=

# 검색엔진 구조화 데이터에 표시할 사업장 정보
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_ADDRESS=

# 카카오맵 JavaScript 키
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# 관리자 로그인 비밀번호
ADMIN_PASSWORD=

# 관리자 로그인 쿠키 서명용 긴 임의 문자열
ADMIN_SESSION_SECRET=

# Resend 문의 답변 이메일 발송 설정
RESEND_API_KEY=
# 예: 백조현대부동산중개 <reply@example.com>
RESEND_FROM_EMAIL=
# 고객이 이메일에 회신할 때 받을 주소 (선택)
RESEND_REPLY_TO_EMAIL=
